# =============================================================================
# Seguridad Alimentaria ERP — variables de entorno (plantilla, SIN valores reales)
# Instancia monocliente: 1 cliente = 1 repo = 1 schema = 1 deploy.
# =============================================================================

# --- Identidad de la instancia (OBLIGATORIO) ---------------------------------
# Esta app SOLO opera sobre el schema `seguridadalimentariaerp`.
# Apuntar estas variables a otro schema operativo hace fallar el arranque a propósito.
APP_DB_SCHEMA=seguridadalimentariaerp
NEXT_PUBLIC_APP_DB_SCHEMA=seguridadalimentariaerp
NEURA_CLIENT_SCHEMA=seguridadalimentariaerp
NEURA_INSTANCE_MODE=single_client
NEURA_CLIENT_NAME=Seguridad Alimentaria
NEXT_PUBLIC_NEURA_CLIENT_NAME=Seguridad Alimentaria

# --- Supabase (self-hosted) --------------------------------------------------
# El schema debe estar expuesto en PostgREST (PGRST_DB_SCHEMAS) o el browser da PGRST106.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Postgres directo (server-side: pools pg, scripts de migración) -----------
SUPABASE_DB_URL=
DATABASE_URL=
DIRECT_URL=

# --- Datos comerciales del membrete de documentos ----------------------------
# PENDIENTE: el cliente todavía no proveyó estos datos. Vacíos = el membrete
# omite la línea (no se inventan datos ni se heredan de otra empresa).
# Listas separadas por "|".
NEURA_EMPRESA_ACTIVIDAD=
NEURA_EMPRESA_TELEFONO=
NEURA_EMPRESA_DIRECCION=
NEURA_EMPRESA_LOGO_URL=

# --- Bootstrap de acceso -----------------------------------------------------
NEXT_PUBLIC_SUPER_ADMIN_EMAILS=

# --- Facturación -------------------------------------------------------------
FACTURA_PREFIJO=
FACTURA_DIAS_CREDITO_DEFAULT=

# --- SIFEN (facturación electrónica) — PENDIENTE de alta fiscal --------------
# NO reutilizar certificados ni claves de otra instancia.
SIFEN_SECRETS_KEY=
SIFEN_WORKER_DISABLED=true

# --- WhatsApp / Omnicanal — PENDIENTE de alta de canal propio ----------------
# NO reutilizar tokens, canales ni WABA de otra instancia.
WHATSAPP_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_GRAPH_VERSION=
WHATSAPP_DEFAULT_EMPRESA_ID=
YCLOUD_WEBHOOK_EMPRESA_ID=
CRM_WEBHOOK_EMPRESA_ID=

# --- Integraciones opcionales ------------------------------------------------
GOOGLE_CLOUD_VISION_API_KEY=
WEBHOOK_URL=
WEBHOOK_SECRET=
